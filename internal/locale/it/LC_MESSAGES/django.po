msgid "Inspection areas"
msgstr "Aree di controllo"

msgid "Result"
msgstr "Risultato"

msgid "Inspection ID"
msgstr "ID del controllo"

msgid "Inspection report PDF"
msgstr "Rapporto di controllo PDF"

msgid "Complete inspection"
msgstr "Concludere il controllo"

msgid "%(counter)s inspection item"
msgid_plural "%(counter)s inspection items"
msgstr[0] "%(counter)s punto di controllo"
msgstr[1] "%(counter)s punti di controllo"

msgid "%(counter)s inspection item is still open."
msgid_plural "%(counter)s inspection items are still open."
msgstr[0] "%(counter)s punto di controllo è ancora aperto."
msgstr[1] "%(counter)s punti di controllo sono ancora aperti."

msgid "All inspection items have been answered. The inspection can be completed."
msgstr "Tutti i punti di controllo sono stati risposti. Il controllo può essere concluso."

msgid "Inspection completed"
msgstr "Controllo concluso"

msgid "This inspection has been completed."
msgstr "Questo controllo è stato concluso."

msgid "Completed on"
msgstr "Concluso il"

msgid "by"
msgstr "da"

msgid "Record inspection answers"
msgstr "Registrare le risposte di controllo"

msgid "Set the status for each inspection item and add a comment if needed."
msgstr "Impostare lo stato per ogni punto di controllo e aggiungere un commento se necessario."

msgid "Save inspection answers"
msgstr "Salvare le risposte di controllo"

msgid "Playground-related inspection items without assignment to a single play equipment item."
msgstr "Punti di controllo relativi al parco giochi senza assegnazione a una singola attrezzatura da gioco."

msgid "No inspection items available"
msgstr "Nessun punto di controllo disponibile"

msgid "No matching inspection items were generated for this inspection area."
msgstr "Per questa area di controllo non sono stati generati punti di controllo corrispondenti."

msgid "Maintenance note"
msgstr "Nota di manutenzione"

msgid "Comment"
msgstr "Commento"

msgid "Optional comment"
msgstr "Commento facoltativo"

msgid "Recorded defects"
msgstr "Difetti registrati"

msgid "Maintenance permission is required to record defects."
msgstr "Per registrare difetti è necessaria un’autorizzazione alla manutenzione."

msgid "No inspection areas available"
msgstr "Nessuna area di controllo disponibile"

msgid "No inspection areas were generated for this inspection."
msgstr "Per questo controllo non sono state generate aree di controllo."

msgid "Inspection areas"
msgstr "Zones de contrôle"

msgid "Result"
msgstr "Résultat"

msgid "Inspection ID"
msgstr "ID du contrôle"

msgid "Inspection report PDF"
msgstr "Rapport de contrôle PDF"

msgid "Complete inspection"
msgstr "Terminer le contrôle"

msgid "%(counter)s inspection item"
msgid_plural "%(counter)s inspection items"
msgstr[0] "%(counter)s point de contrôle"
msgstr[1] "%(counter)s points de contrôle"

msgid "%(counter)s inspection item is still open."
msgid_plural "%(counter)s inspection items are still open."
msgstr[0] "%(counter)s point de contrôle est encore ouvert."
msgstr[1] "%(counter)s points de contrôle sont encore ouverts."

msgid "All inspection items have been answered. The inspection can be completed."
msgstr "Tous les points de contrôle ont été traités. Le contrôle peut être terminé."

msgid "Inspection completed"
msgstr "Contrôle terminé"

msgid "This inspection has been completed."
msgstr "Ce contrôle a été terminé."

msgid "Completed on"
msgstr "Terminé le"

msgid "by"
msgstr "par"

msgid "Record inspection answers"
msgstr "Saisir les réponses de contrôle"

msgid "Set the status for each inspection item and add a comment if needed."
msgstr "Définissez le statut de chaque point de contrôle et ajoutez un commentaire si nécessaire."

msgid "Save inspection answers"
msgstr "Enregistrer les réponses de contrôle"

msgid "Playground-related inspection items without assignment to a single play equipment item."
msgstr "Points de contrôle liés à la place de jeux sans attribution à un équipement de jeu précis."

msgid "No inspection items available"
msgstr "Aucun point de contrôle disponible"

msgid "No matching inspection items were generated for this inspection area."
msgstr "Aucun point de contrôle correspondant n’a été généré pour cette zone de contrôle."

msgid "Maintenance note"
msgstr "Remarque d’entretien"

msgid "Comment"
msgstr "Commentaire"

msgid "Optional comment"
msgstr "Commentaire facultatif"

msgid "Recorded defects"
msgstr "Défauts saisis"

msgid "Maintenance permission is required to record defects."
msgstr "Une autorisation de maintenance est nécessaire pour saisir des défauts."

msgid "No inspection areas available"
msgstr "Aucune zone de contrôle disponible"

msgid "No inspection areas were generated for this inspection."
msgstr "Aucune zone de contrôle n’a été générée pour ce contrôle."
